---
const features = [
  {
    badge: "Speed",
    title: "Responds in 60 Seconds",
    description: "Your AI replies to every new lead within 60 seconds. Day or night. Whether you're on a call, at dinner, or asleep.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1849D6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/><path d="M22 12h-2"/></svg>`,
  },
  {
    badge: "Qualifies",
    title: "Filters Out Time-Wasters",
    description: "Asks the right questions, filters out the wrong people, and only forwards leads worth your time — using your exact criteria.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1849D6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>`,
  },
  {
    badge: "Books",
    title: "Books Calls Automatically",
    description: "No booking links. No back and forth. The AI guides the conversation and locks the appointment directly into your calendar.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1849D6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><polyline points="9 16 11 18 15 14"/></svg>`,
  },
  {
    badge: "Follow-Up",
    title: "Follows Up for 90 Days",
    description: "Most leads don't convert on message #1. Your AI follows up consistently for 90 days without you ever touching it.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1849D6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>`,
  },
];
---

<section class="bg-white py-20" id="features">
  <div class="site-container">

    <!-- Header -->
    <div class="text-center mb-14">
      <span class="inline-flex items-center bg-ink text-white text-xs font-black uppercase tracking-[0.15em] px-5 py-2 rounded-full mb-6">
        The Solution
      </span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight leading-tight text-ink">
        A Custom AI Setter<br />
        That <span class="hl-yellow-full">Never Sleeps.</span>
      </h2>
      <p class="text-muted text-base leading-relaxed max-w-2xl mx-auto mt-6" style="font-weight:400;">
        Not a template. Not a chatbot. A done-for-you AI built from scratch around <strong class="text-ink font-semibold">your</strong> business,
        your offers, and the exact way you qualify a lead.
      </p>
    </div>

    <!-- 2x2 Feature grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {features.map((f) => (
        <div class="relative bg-white border border-gray-200 rounded-2xl p-8 pt-10 shadow-sm">
          <!-- Overlapping badge -->
          <span class="absolute -top-3.5 left-6 bg-yellow text-ink text-xs font-black uppercase tracking-[0.15em] px-4 py-1.5 rounded-full">
            {f.badge}
          </span>

          <!-- Icon box -->
          <div class="w-14 h-14 border-2 border-yellow rounded-xl flex items-center justify-center mb-6 bg-white">
            <Fragment set:html={f.icon} />
          </div>

          <!-- Content -->
          <h3 class="text-2xl font-black text-ink mb-3">{f.title}</h3>
          <p class="text-muted text-base leading-relaxed" style="font-weight:400;">{f.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>
