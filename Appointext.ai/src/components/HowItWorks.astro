---
const steps = [
  { step: "Step 01", title: "Pay $99 & book your call",     description: "Takes 2 minutes. Pick whatever time works for you. Secure checkout. Your $99 goes toward your full build." },
  { step: "Step 02", title: "20-minute strategy call",       description: "We learn your business, your leads, and how you qualify. No homework needed. No pitch deck, just a real conversation." },
  { step: "Step 03", title: "We build your AI in 3-7 days", description: "Conversation flows, qualification questions, follow-up sequences, calendar integration, all built from scratch around you." },
  { step: "Step 04", title: "Go live & start booking",       description: "Every new lead gets followed up with in 60 seconds. Automatically. While you focus on closing and delivering." },
];
---

<section class="bg-white dotted-bg py-20" id="how-it-works">
  <div class="site-container">

    <div class="text-center mb-14">
      <span class="inline-flex items-center bg-yellow text-ink text-xs font-black uppercase tracking-[0.15em] px-5 py-2 rounded-full mb-6">How It Works</span>
      <h2 class="text-4xl md:text-5xl font-black tracking-tight leading-tight text-ink">
        From lead to booked call &mdash;<br />in <span class="text-blue">4 simple steps.</span>
      </h2>
      <p class="text-muted text-base mt-5" style="font-weight:400;">No manual work. No missed leads. Just revenue on autopilot.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 max-w-5xl mx-auto">

      <div class="relative bg-white border border-gray-200 rounded-2xl p-6 pt-10 shadow-sm">
        <span class="absolute -top-3.5 left-5 bg-ink text-white text-xs font-black uppercase tracking-[0.12em] px-4 py-1.5 rounded-full">Step 01</span>
        <div class="w-12 h-12 border-2 border-yellow rounded-xl flex items-center justify-center mb-5 bg-white">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1849D6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="5" width="20" height="14" rx="2"></rect>
            <line x1="2" y1="10" x2="22" y2="10"></line>
          </svg>
        </div>
        <h3 class="text-ink text-base font-bold mb-2">{steps[0].title}</h3>
        <p class="text-muted text-base leading-relaxed" style="font-weight:400;">{steps[0].description}</p>
      </div>

      <div class="relative bg-white border border-gray-200 rounded-2xl p-6 pt-10 shadow-sm">
        <span class="absolute -top-3.5 left-5 bg-ink text-white text-xs font-black uppercase tracking-[0.12em] px-4 py-1.5 rounded-full">Step 02</span>
        <div class="w-12 h-12 border-2 border-yellow rounded-xl flex items-center justify-center mb-5 bg-white">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1849D6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6.91-6.91 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.12.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.58 2.81.7A2 2 0 0 1 22 15.1v1.82z"></path>
          </svg>
        </div>
        <h3 class="text-ink text-base font-bold mb-2">{steps[1].title}</h3>
        <p class="text-muted text-base leading-relaxed" style="font-weight:400;">{steps[1].description}</p>
      </div>

      <div class="relative bg-white border border-gray-200 rounded-2xl p-6 pt-10 shadow-sm">
        <span class="absolute -top-3.5 left-5 bg-ink text-white text-xs font-black uppercase tracking-[0.12em] px-4 py-1.5 rounded-full">Step 03</span>
        <div class="w-12 h-12 border-2 border-yellow rounded-xl flex items-center justify-center mb-5 bg-white">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1849D6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="4" y="4" width="16" height="16" rx="2"></rect>
            <rect x="9" y="9" width="6" height="6"></rect>
            <line x1="9" y1="1" x2="9" y2="4"></line>
            <line x1="15" y1="1" x2="15" y2="4"></line>
            <line x1="9" y1="20" x2="9" y2="23"></line>
            <line x1="15" y1="20" x2="15" y2="23"></line>
            <line x1="20" y1="9" x2="23" y2="9"></line>
            <line x1="20" y1="14" x2="23" y2="14"></line>
            <line x1="1" y1="9" x2="4" y2="9"></line>
            <line x1="1" y1="14" x2="4" y2="14"></line>
          </svg>
        </div>
        <h3 class="text-ink text-base font-bold mb-2">{steps[2].title}</h3>
        <p class="text-muted text-base leading-relaxed" style="font-weight:400;">{steps[2].description}</p>
      </div>

      <div class="relative bg-white border border-gray-200 rounded-2xl p-6 pt-10 shadow-sm">
        <span class="absolute -top-3.5 left-5 bg-ink text-white text-xs font-black uppercase tracking-[0.12em] px-4 py-1.5 rounded-full">Step 04</span>
        <div class="w-12 h-12 border-2 border-yellow rounded-xl flex items-center justify-center mb-5 bg-white">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1849D6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"></path>
            <path d="M12 15 9 12a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"></path>
            <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"></path>
            <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"></path>
          </svg>
        </div>
        <h3 class="text-ink text-base font-bold mb-2">{steps[3].title}</h3>
        <p class="text-muted text-base leading-relaxed" style="font-weight:400;">{steps[3].description}</p>
      </div>

    </div>
  </div>
</section>