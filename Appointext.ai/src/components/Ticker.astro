    label: "Cleaning",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FFD900" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 22l4-4"/><path d="M7 18c0-3 2-5 5-5s5-2 5-5V3"/><path d="M12 8c0 2-1 3-3 4"/><circle cx="17" cy="3" r="1"/></svg>`
  },
];
---

<div class="bg-ink py-8 overflow-hidden border-y border-white/10" aria-hidden="true">
  <div class="flex items-center whitespace-nowrap ticker-track">
    {[...items, ...items, ...items].map((item) => (
      <span class="inline-flex items-center gap-3 mx-10 shrink-0">
        <Fragment set:html={item.icon} />
        <span class="font-bold tracking-wide" style="font-size:24px; color:#E8EAF0;">{item.label}</span>
      </span>
    ))}
  </div>
</div>

<style>
  @keyframes marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-33.333%); }
  }

  .ticker-track {
    animation: marquee 18s linear infinite;
  }

  @media (max-width: 767px) {
    .ticker-track {
      animation-duration: 6s;
    }
    .ticker-track span span {
      font-size: 15px !important;
    }
    .ticker-track span svg {
      width: 15px;
      height: 15px;
    }
  }
</style>
