---
const faqs = [
  {
    q: "Will my leads know it's an AI?",
    a: "Only if you tell them. It's built from scratch around your business — your tone, your offers, your qualifying questions. Natural, conversational, and human. Most leads assume they're texting your team.",
  },
  {
    q: "Is this a template or actually custom?",
    a: "100% custom. Every conversation flow, qualification logic, follow-up sequence, and tone is built from scratch for your business during the strategy call and the 3-7 day build. No two AppoinText AIs are the same.",
  },
  {
    q: "I've tried AI tools before and they were terrible. How is this different?",
    a: "Those were templates dressed up as AI. You signed up and were left to configure it yourself. Ours is done-for-you, built by us, deployed by us, and trained on your real qualifying criteria — not generic templates.",
  },
  {
    q: "How long does setup take?",
    a: "3 to 7 days from your strategy call. Most businesses are live within the first week. We handle every part of the build — you don't touch a thing.",
  },
  {
    q: "Do I need any technical skills?",
    a: "Zero. We integrate with your existing tools (calendar, CRM, lead sources). You don't touch code, prompts, or settings. We send you a working AI and a walkthrough.",
  },
  {
    q: "Why only $99 when it's normally up to $3,797?",
    a: "We want 10 fresh case studies this month. You get up to $3,797 in value for $99 — and we get a portfolio win. Once the 10 spots are filled, pricing returns to normal.",
  },
  {
    q: "How is pricing structured after the first month?",
    a: "First month is included with your $99 build. After that, you continue on a flat monthly retainer for hosting, maintenance, optimization, and continued tuning. We'll cover this on the strategy call — no surprises.",
  },
  {
    q: "What if it doesn't work for my business?",
    a: "Get on the strategy call. If we don't think it's a fit — or you don't — we refund your $99 on the spot. You either walk away with a custom AI being built, or with your money back.",
  },
];
---

<section class="bg-white py-24" id="faq">
  <div class="site-container">

    <!-- Header -->
    <div class="text-center mb-12">
      <span class="inline-flex items-center bg-yellow text-ink text-xs font-black uppercase tracking-[0.15em] px-5 py-2 rounded-full mb-7">
        Questions? We've got answers.
      </span>
      <h2 class="text-4xl md:text-5xl font-black tracking-tight leading-tight text-ink">
        Frequently Asked<br />
        <span class="text-blue">Questions.</span>
      </h2>
    </div>

    <!-- Accordion -->
    <div class="max-w-2xl mx-auto space-y-3" id="faq-list">
      {faqs.map((item, i) => (
        <div class="faq-item border border-gray-200 rounded-2xl overflow-hidden" data-index={i}>
          <button
            class="faq-trigger w-full flex items-center justify-between text-left px-6 py-5 gap-4"
            aria-expanded={i === 0 ? "true" : "false"}
          >
            <span class="text-ink font-semibold text-base">{item.q}</span>
            <svg class="faq-icon shrink-0 transition-transform duration-300" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#5B6480" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>
          <div class="faq-body overflow-hidden transition-[max-height] duration-300 ease-in-out" style={i === 0 ? "max-height:500px;" : "max-height:0;"}>
            <p class="text-muted text-sm leading-relaxed px-6 pb-6" style="font-weight:400;">{item.a}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  document.querySelectorAll('.faq-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const body = item.querySelector('.faq-body');
      const icon = btn.querySelector('.faq-icon');
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      // Close all
      document.querySelectorAll('.faq-item').forEach((el) => {
        el.querySelector('.faq-trigger').setAttribute('aria-expanded', 'false');
        (el.querySelector('.faq-body') as HTMLElement).style.maxHeight = '0';
        (el.querySelector('.faq-icon') as HTMLElement).style.transform = 'rotate(0deg)';
      });

      // Open clicked if it was closed
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        (body as HTMLElement).style.maxHeight = '500px';
        (icon as HTMLElement).style.transform = 'rotate(180deg)';
      }
    });
  });
</script>