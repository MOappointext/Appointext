<section class="bg-white py-20" id="guarantee">
  <div class="site-container">

    <div class="border-2 border-yellow rounded-3xl px-[10px] py-6 md:p-14 max-w-5xl mx-auto">
      <div class="flex flex-col md:flex-row items-center gap-10">

        <!-- Left: founder photo + shield badge -->
        <div class="relative shrink-0">
          <img
            src="/ca061c9b88c282cd08d060c3f26c127b750aae78c49f2f9274ca35421f866877.webp"
            alt="Founder"
            width="192" height="208" loading="lazy" class="w-48 h-52 rounded-2xl object-cover object-top"
          />
          <div class="absolute -bottom-4 -right-4 w-12 h-12 rounded-full bg-yellow flex items-center justify-center shadow-lg">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <polyline points="9 12 11 14 15 10"/>
            </svg>
          </div>
        </div>

        <!-- Right: content -->
        <div class="flex-1">

          <span class="inline-flex items-center gap-2 bg-ink text-white text-xs font-black uppercase tracking-[0.15em] px-5 py-2 rounded-full mb-6">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            Our Straight-Up Guarantee
          </span>

          <h2 class="text-3xl md:text-4xl lg:text-5xl font-black tracking-tight leading-tight text-ink mb-5">
            Walk away with a custom AI &mdash;<br />
            <span class="text-blue">or your money back.</span>
          </h2>

          <p class="text-muted text-base leading-relaxed mb-8" style="font-weight:400;">
            Get on the strategy call. We'll walk you through exactly what we'd build for <strong class="text-ink font-semibold">your</strong> business. If at any point during that call you don't feel this is the <strong class="text-ink font-semibold">right fit</strong> &mdash; <strong class="text-ink font-semibold">we refund your $99 on the spot.</strong> No forms. No waiting. No questions asked.
          </p>

          <div class="flex flex-wrap gap-3">
            <span class="inline-flex items-center gap-2 border border-gray-200 text-ink text-sm font-semibold px-5 py-2.5 rounded-full">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#1849D6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              Refund on the call
            </span>
            <span class="inline-flex items-center gap-2 border border-gray-200 text-ink text-sm font-semibold px-5 py-2.5 rounded-full">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#1849D6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              No forms to fill
            </span>
            <span class="inline-flex items-center gap-2 border border-gray-200 text-ink text-sm font-semibold px-5 py-2.5 rounded-full">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#1849D6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              No questions asked
            </span>
          </div>

        </div>
      </div>
    </div>

  </div>
</section>