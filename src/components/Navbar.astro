---
interface Props {
  showCta?: boolean;
}
const { showCta = true } = Astro.props;
const isHome = Astro.url.pathname === '/';
const h = (anchor: string) => isHome ? anchor : `/${anchor}`;
---

<header class="bg-ink sticky top-0 z-50 border-b border-white/10">
  <nav class="site-container h-[68px] flex items-center justify-between gap-8">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 shrink-0" data-testid="nav-logo">
      <img src="/logo.webp" alt="AppoinText logo" width="32" height="32" class="w-8 h-8 object-contain" />
      <div class="flex flex-col leading-none">
        <span class="text-white font-black text-lg tracking-tight leading-tight">Appointext<span class="text-blue">.ai</span></span>
        <span class="text-white/40 text-[10px] font-medium tracking-wide leading-tight">Custom AI Setters · Done For You</span>
      </div>
    </a>

    <!-- Nav links -->
    <ul class="hidden md:flex items-center gap-7 text-sm font-semibold text-white/80">
      <li><a href={h('#how-it-works')} class="hover:text-white transition-colors whitespace-nowrap">How It Works</a></li>
      <li><a href={h('#features')}    class="hover:text-white transition-colors">Features</a></li>
      <li><a href={h('#results')}     class="hover:text-white transition-colors">Testimonials</a></li>
      <li><a href={h('#faq')}         class="hover:text-white transition-colors">FAQ</a></li>
    </ul>

    <!-- CTA -->
    {showCta && (
      <a
        href={h('#pricing')}
        data-testid="nav-cta"
        class="hidden md:inline-flex items-center gap-1.5 bg-yellow text-ink font-black
               text-sm px-6 py-3 rounded-full hover:bg-yellow-soft transition-colors
               whitespace-nowrap shrink-0"
      >
        Claim $99 Spot &nbsp;→
      </a>
    )}

    <!-- Mobile burger -->
    <button class="md:hidden text-white ml-auto" aria-label="Menu">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="3" y1="6"  x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>

  </nav>
</header>
