---
---

<div class="w-full mx-auto">

  <!-- $99 today badge — always visible at top -->
  <div class="text-center mb-6">
    <span class="inline-flex items-center gap-2 bg-yellow text-ink font-black text-sm
                 uppercase tracking-[0.12em] px-5 py-2 rounded-full shadow-sm">
      $99 today — Only 10 spots left
    </span>
  </div>

  <!-- Gate: shown by default -->
  <div id="video-gate" data-testid="video-gate"
       class="bg-gray-50 border border-gray-200 rounded-2xl p-10 shadow-sm max-w-2xl mx-auto">

    <!-- Pulsing play icon -->
    <div class="flex flex-col items-center mb-6">
      <div class="relative flex items-center justify-center mb-4">
        <span class="absolute inline-flex h-20 w-20 rounded-full bg-blue/10 animate-ping"></span>
        <span class="absolute inline-flex h-16 w-16 rounded-full bg-blue/15"></span>
        <div class="relative z-10 w-14 h-14 bg-blue rounded-full flex items-center justify-center shadow-lg">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="white">
            <polygon points="6,4 20,12 6,20"/>
          </svg>
        </div>
      </div>
      <span class="inline-flex items-center gap-1.5 bg-yellow text-ink text-xs font-bold
                   uppercase tracking-[0.12em] px-3 py-1 rounded-full">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18 8h-1V6A5 5 0 0 0 7 6v2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2zm-6 9a2 2 0 1 1 0-4 2 2 0 0 1 0 4zm3-9H9V6a3 3 0 0 1 6 0v2z"/>
        </svg>
        Video Locked
      </span>
    </div>

    <h3 class="text-2xl font-black text-ink mb-1 text-center">Watch the Full Breakdown</h3>
    <p class="text-muted text-sm mb-6 text-center">Enter your details below to unlock the video instantly.</p>

    <div class="space-y-3">
      <input id="lead-name" type="text" placeholder="Full Name" data-testid="input-name"
        class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm font-medium
               focus:outline-none focus:border-blue transition-colors" />
      <input id="lead-email" type="email" placeholder="Email Address" data-testid="input-email"
        class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm font-medium
               focus:outline-none focus:border-blue transition-colors" />
      <input id="lead-phone" type="tel" placeholder="Phone Number" data-testid="input-phone"
        class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm font-medium
               focus:outline-none focus:border-blue transition-colors" />

      <button onclick="unlockVideo()" data-testid="unlock-btn"
        class="w-full bg-blue text-white font-black py-4 rounded-full
               hover:bg-blue-hover transition-colors animate-pulse-soft mt-2 text-base">
        🔓 Unlock Free Video
      </button>
    </div>

    <p class="text-muted text-xs text-center mt-4">
      🔒 No spam. Your info is safe and never shared.
    </p>
  </div>

  <!-- Video: hidden until form submitted -->
  <div id="video-player" class="hidden mx-auto w-full" style="max-width:1000px" data-testid="video-player">
    <div class="rounded-2xl overflow-hidden shadow-2xl border border-gray-100" style="position:relative;aspect-ratio:16/9;">
      <iframe
        loading="lazy"
        title="Gumlet video player"
        src="https://play.gumlet.io/embed/6a21e7ba27d928a32f34dc4a"
        style="border:none; position:absolute; top:0; left:0; height:100%; width:100%;"
        referrerpolicy="origin"
        allow="accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture; fullscreen; clipboard-write"
      ></iframe>
    </div>
    <p class="text-center text-muted text-sm mt-4">
      👇 Watch the short video, then scroll for everything that's included.
    </p>
  </div>

  <!-- Stripe CTA: hidden until form submitted -->
  <div id="stripe-cta" class="hidden text-center mt-8" data-testid="stripe-cta">
    <a href="https://buy.stripe.com/8x2bIUgauclZglv5Uv7bW08" data-testid="stripe-btn"
       class="inline-flex items-center gap-2 bg-blue text-white font-black
              text-lg px-10 py-5 rounded-full hover:bg-blue-hover
              transition-transform active:scale-95 animate-pulse-soft">
      Claim My $99 Spot →
    </a>
    <p class="text-ink text-sm font-bold mt-4 tracking-wide">
      ✓ Secure checkout &nbsp;·&nbsp; ✓ Only 10 spots left
    </p>
  </div>

</div>

<script>
async function unlockVideo() {
  const name  = (document.getElementById('lead-name')  as HTMLInputElement).value.trim();
  const email = (document.getElementById('lead-email') as HTMLInputElement).value.trim();
  const phone = (document.getElementById('lead-phone') as HTMLInputElement).value.trim();

  if (!name || !email || !phone) {
    alert('Please fill in all fields to unlock the video.');
    return;
  }

  try {
    await fetch('https://services.leadconnectorhq.com/hooks/XLiMPuVzCRrbQ48wmWVU/webhook-trigger/81dd2762-c946-47f9-bba5-5d52496554df', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, email, phone, tag: 'Lead', source: 'VSL Form' }),
    });
  } catch (err) {
    console.error('Webhook error:', err);
  }

  document.getElementById('video-gate')!.classList.add('hidden');

  const player = document.getElementById('video-player')!;
  player.classList.remove('hidden');

document.getElementById('stripe-cta')!.classList.remove('hidden');

  player.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

(window as any).unlockVideo = unlockVideo;
</script>
