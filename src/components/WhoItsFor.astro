---
const smallCards = [
  {
    title: "Agencies",
    description: "Never lose a client enquiry to slow follow up again.",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FFD900" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>`,
  },
  {
    title: "Med Spas",
    description: "Fill your calendar without chasing leads manually.",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FFD900" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  },
  {
    title: "Service Businesses",
    description: "Respond to every missed call before your competitor does.",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FFD900" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  },
  {
    title: "Hair Studios",
    description: "Re-book regulars and convert new walk-ins on autopilot.",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FFD900" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>`,
  },
];

const bottomCards = [
  {
    title: "Auto Dealers",
    description: "Qualify trade-in & test-drive leads in under a minute.",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FFD900" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 17H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v9a2 2 0 0 1-2 2h-2"/><circle cx="9" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>`,
  },
  {
    title: "Fitness Studios",
    description: "Turn every lead into a booked free-class trial.",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FFD900" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6.5 6.5h11"/><path d="M6.5 17.5h11"/><path d="M3 9.5h2v5H3z"/><path d="M19 9.5h2v5h-2z"/><path d="M5 12h14"/></svg>`,
  },
  {
    title: "Dental & Health",
    description: "Convert insurance enquiries before they go cold.",
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FFD900" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>`,
  },
];
---

<section class="bg-dark dotted-bg-dark py-24" id="who-its-for">
  <div class="site-container">

    <!-- Header -->
    <div class="text-center mb-14">
      <span class="inline-flex items-center bg-yellow text-ink text-xs font-black uppercase tracking-[0.15em] px-5 py-2 rounded-full mb-6">
        Who It's For
      </span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight leading-tight text-white">
        Built for <span class="underline decoration-yellow decoration-4 underline-offset-4">any business</span><br />
        that runs on <span class="hl-yellow-full">appointments.</span>
      </h2>
    </div>

    <!-- Top grid: large card + 2x2 -->
    <div class="grid grid-cols-1 md:grid-cols-5 gap-4 mb-4 max-w-4xl mx-auto">

      <!-- Large hero card -->
      <div class="md:col-span-3 bg-surface border border-white/10 rounded-2xl p-8 flex flex-col justify-between">
        <div>
          <span class="inline-flex items-center gap-1.5 bg-yellow text-ink text-xs font-black uppercase tracking-[0.15em] px-4 py-1.5 rounded-full mb-6">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
            Primary Fit
          </span>
          <h3 class="text-white text-3xl font-bold mb-4">Coaches &amp; Consultants</h3>
          <p class="text-white/60 text-base leading-relaxed" style="font-weight:400;">
            You're running traffic. People are opting in. But half never book a call. Your AI follows up with every single one, qualifies them on your criteria, and gets them booked — while you're coaching, creating, or off the clock.
          </p>
        </div>
      </div>

      <!-- 2x2 small cards -->
      <div class="md:col-span-2 grid grid-cols-2 gap-4">
        {smallCards.map((card) => (
          <div class="bg-surface border border-white/10 rounded-2xl p-5 hover:border-yellow/30 transition-colors">
            <div class="mb-3">
              <Fragment set:html={card.icon} />
            </div>
            <h3 class="text-white font-bold text-base mb-1">{card.title}</h3>
            <p class="text-white/50 text-sm leading-relaxed" style="font-weight:400;">{card.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom row: 3 equal cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 max-w-4xl mx-auto">
      {bottomCards.map((card) => (
        <div class="bg-surface border border-white/10 rounded-2xl p-6 hover:border-yellow/30 transition-colors">
          <div class="mb-3">
            <Fragment set:html={card.icon} />
          </div>
          <h3 class="text-white font-bold text-base mb-1">{card.title}</h3>
          <p class="text-white/50 text-sm leading-relaxed" style="font-weight:400;">{card.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>
