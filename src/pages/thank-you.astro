---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="You're In — AppoinText AI">

  <main class="bg-ink dotted-bg-dark">

    <!-- Hero -->
    <section class="py-20 text-center">
      <div class="site-container max-w-3xl mx-auto">

        <div class="inline-flex items-center gap-2 bg-yellow/10 border border-yellow/30 text-yellow text-xs font-black uppercase tracking-[0.15em] px-5 py-2 rounded-full mb-8">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
          Payment Confirmed
        </div>

        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black tracking-tight leading-tight text-white mb-6">
          You're In.<br />
          <span class="hl-yellow-full">Let's Build Your AI.</span>
        </h1>

        <p class="text-white/60 text-base md:text-lg leading-relaxed max-w-xl mx-auto mb-12" style="font-weight:400;">
          Welcome to AppoinText. Watch the short video below, then book your onboarding call directly into our calendar — we'll go over your custom build.
        </p>

        <!-- Video -->
        <div class="rounded-2xl overflow-hidden shadow-2xl border border-white/10 max-w-2xl mx-auto mb-16" style="position:relative;aspect-ratio:16/9;">
          <iframe
            loading="lazy"
            title="Gumlet video player"
            src="https://play.gumlet.io/embed/6a21e7baf10590fd5261761b?preload=false&autoplay=false&loop=false&hide_speed=true&hide_share=true&hide_download=true&hide_cast=true&watermark=false"
            style="border:none; position:absolute; top:0; left:0; height:100%; width:100%;"
            referrerpolicy="origin"
            allow="accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture; fullscreen; clipboard-write"
          ></iframe>
        </div>

        <!-- Calendly CTA badge -->
        <span class="inline-flex items-center gap-2 bg-yellow text-ink font-black text-xs uppercase tracking-[0.15em] px-6 py-2.5 rounded-full mb-6">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          Book Your Onboarding Call
        </span>

        <h2 class="text-2xl md:text-3xl font-black text-white mb-8">Pick a time that works for you</h2>

        <!-- Booking embed -->
        <div class="bg-white rounded-2xl overflow-hidden shadow-2xl mb-16 max-w-2xl mx-auto">
          <iframe src="https://sms.appointext.ai/widget/booking/ulDVKlUfE37eNoM1vaxC" style="width:100%;border:none;overflow:hidden;" scrolling="no" id="ulDVKlUfE37eNoM1vaxC_1781023551587"></iframe>
          <script is:inline src="https://sms.appointext.ai/js/form_embed.js" type="text/javascript"></script>
        </div>

        <!-- What happens next -->
        <div class="bg-white/5 border border-white/10 rounded-2xl p-8 text-left max-w-2xl mx-auto mb-16">
          <h3 class="text-yellow font-black text-sm uppercase tracking-[0.15em] mb-6">What happens next</h3>
          <ol class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-yellow text-ink text-xs font-black flex items-center justify-center shrink-0 mt-0.5">1</span>
              <p class="text-white text-sm leading-relaxed" style="font-weight:400;">You'll get a confirmation email with your booking details.</p>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-yellow text-ink text-xs font-black flex items-center justify-center shrink-0 mt-0.5">2</span>
              <p class="text-white text-sm leading-relaxed" style="font-weight:400;">On the call we map your business, your offers, and how you qualify a lead.</p>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-yellow text-ink text-xs font-black flex items-center justify-center shrink-0 mt-0.5">3</span>
              <p class="text-white text-sm leading-relaxed" style="font-weight:400;">We build your custom AI setter and go live in 4–5 days.</p>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-yellow text-ink text-xs font-black flex items-center justify-center shrink-0 mt-0.5">4</span>
              <p class="text-white text-sm leading-relaxed" style="font-weight:400;">Your first month is included. Pricing after that is custom and we'll confirm on the call.</p>
            </li>
          </ol>
        </div>

        <!-- Back to home -->
        <a href="/" class="inline-flex items-center gap-2 text-white/40 hover:text-white text-sm font-medium transition-colors">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
          Back to homepage
        </a>

      </div>
    </section>

  </main>


</BaseLayout>